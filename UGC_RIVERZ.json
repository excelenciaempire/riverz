    {
      "parameters": {
        "jsCode": "// Run Once for All Items\nconst items = $input.all();\nconst exts = /\\.(mp4|mov|webm|m3u8)(\\?|$)/i;\n\nfunction pickUrl(obj) {\n  if (!obj || typeof obj !== 'object') return null;\n\n  // common direct keys\n  for (const k of ['video_url','videoUrl','url','uri']) {\n    const v = obj[k];\n    if (typeof v === 'string' && exts.test(v)) return v.trim();\n  }\n\n  // common nested shapes\n  const cand =\n    obj.video?.url || obj.video?.uri ||\n    obj.output?.video?.url || obj.output?.video?.uri ||\n    obj.output?.video_url;\n  if (typeof cand === 'string' && exts.test(cand)) return cand.trim();\n\n  // deep scan\n  const stack = [obj], seen = new Set();\n  while (stack.length) {\n    const cur = stack.pop();\n    if (!cur || typeof cur !== 'object' || seen.has(cur)) continue;\n    seen.add(cur);\n\n    for (const val of Object.values(cur)) {\n      if (typeof val === 'string' && exts.test(val)) return val.trim();\n      if (Array.isArray(val)) {\n        for (const e of val) {\n          if (typeof e === 'string' && exts.test(e)) return e.trim();\n          if (e && typeof e === 'object') stack.push(e);\n        }\n      } else if (val && typeof val === 'object') {\n        stack.push(val);\n      }\n    }\n  }\n  return null;\n}\n\nconst urls = Array.from(new Set(items.map(it => pickUrl(it.json)).filter(Boolean)));\nconst quotedCsv = urls.map(u => `\"${u}\"`).join(',');\n\nreturn [{ json: { video_urls: quotedCsv } }];\n"
      },
