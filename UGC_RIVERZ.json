      "parameters": {
        "jsCode": "// Prefer 2nd image_url, else 1st. Return ONE item.\nconst items = $input.all();\n\nconst pickUrl = (it) => {\n  if (!it) return null;\n  const j = it.json || {};\n  // Try common shapes\n  const url =\n    j.image_url ??\n    j.last_frame_url ??\n    j.images?.[0]?.url ??\n    j[\"last_frame \"]; // handles accidental trailing space\n  if (typeof url !== 'string') return null;\n  const u = url.trim();\n  return u && u !== 'null' && u !== 'undefined' ? u : null;\n};\n\nconst second = pickUrl(items[1]);\nconst first  = pickUrl(items[0]);\n\nconst chosen = second ?? first ?? null;\nreturn [{ json: { image_url: chosen } }];\n"
      },
