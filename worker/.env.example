# Supabase service-role credentials (do NOT use anon key here).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Bucket name in Supabase Storage where intermediate + final assets live.
STEALER_BUCKET=stealer

# kie.ai credentials.
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai

# OpenAI for Whisper STT.
OPENAI_API_KEY=

# ElevenLabs for TTS / voice cloning. (Used in Phase 4.)
ELEVENLABS_API_KEY=

# Loop tuning.
WORKER_POLL_INTERVAL_MS=10000
WORKER_BATCH_SIZE=5
WORKER_ID=stealer-worker-1

# Where the worker writes scratch files (mounted volume in production).
STEALER_TMP_DIR=/tmp/stealer

# (Phase 5) Public URL of the Next.js app and shared secret used to register
# kie.ai's veo callbacks. When unset the worker falls back to polling-only.
PUBLIC_APP_URL=
STEALER_WEBHOOK_SECRET=
